# ==============================================================================
# Variables de entorno — Laboratorio ELK Stack
# ==============================================================================
# Copia este archivo a `.env` y completa los valores para tu entorno.
#   cp .env.example .env
#
# NUNCA subas tu archivo `.env` con valores reales al repositorio.
# Ver SECURITY.md y docs/conventions/secrets.md.
#
# NOTA: este laboratorio corre principalmente vía docker-compose. Estas variables
# aplican al ejecutar la app Node.js de forma local (`npm start`) o para ajustar
# el entorno de los contenedores.
# ==============================================================================

# ── Aplicación Node.js ────────────────────────────────────────────────────
# Entorno de ejecución: development | production
NODE_ENV=development
# Puerto en el que escucha la aplicación (el contenedor expone 5000 → host 5001)
PORT=5000
# Nivel de log de Winston: debug | info | warn | error
LOG_LEVEL=info

# ── Elasticsearch ─────────────────────────────────────────────────────────
# Host(s) del clúster de Elasticsearch
ELASTICSEARCH_HOSTS=http://localhost:9200

# ── Kibana ────────────────────────────────────────────────────────────────
# URL pública de Kibana
KIBANA_URL=http://localhost:5601
